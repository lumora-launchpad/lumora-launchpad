# Address of the deployed LaunchpadFactory on Base.
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Address of the deployed CampaignFactory (demand gated launch campaigns).
NEXT_PUBLIC_CAMPAIGN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect project id from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_ID=

# Chain to target. Use 8453 for Base mainnet or 84532 for Base Sepolia.
NEXT_PUBLIC_CHAIN_ID=84532

# Block where the factory was deployed. Bounds event log scans so public RPCs do
# not reject a too wide getLogs range. Leave 0 to scan from start.
NEXT_PUBLIC_START_BLOCK=0

# Public site URL, used to build absolute OG image links for shared token pages.
NEXT_PUBLIC_SITE_URL=https://lumora.men

# Block explorer base URL. Defaults to the active chain's explorer (Basescan).
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org

# Set to true once the contracts are verified on the explorer, which shows the
# verified badge on the contracts page.
NEXT_PUBLIC_CONTRACTS_VERIFIED=false
